# ── Supabase ────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Admin / host ────────────────────────────────────────────
# The phone number that unlocks the Host Dashboard.
NEXT_PUBLIC_ADMIN_PHONE=0782173172

# ── Registration sheet (published-to-web CSV) ───────────────
# File → Share → Publish to web → CSV → paste the URL here.
# Until you publish it, the app falls back to the seed list in
# src/lib/attendees-seed.ts so login still works for testing.
NEXT_PUBLIC_REGISTRATION_CSV_URL=

# ── Event links ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSf2wdizy1jwxNhfeHfkK9ifMZW4O2OO7LpoinSSoY0DODbWSQ/viewform
NEXT_PUBLIC_GOOGLE_MEET_URL=https://meet.google.com/dkw-qmct-qui
